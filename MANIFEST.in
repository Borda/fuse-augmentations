# Manifest syntax https://docs.python.org/2/distutils/sourcedist.html
graft wheelhouse

recursive-exclude __pycache__  *.py[cod] *.orig

# Include the README
include *.md
recursive-include fuse_augmentations *.md

# Include the license file
include LICENSE

# Exclude build configs
exclude *.yml
exclude *.yaml
exclude *.toml

prune .git
prune .github
prune temp*
prune test*
prune docs*
